# ─── Vinly Community Starter Environment ────────────────────────────────────
#
# Copy this file to .env.local to get started:
#   cp .env.example .env.local
#
# ─── Demo Mode ──────────────────────────────────────────────────────────────
#
# When true, the app runs entirely offline with mock data.
# No internet connection or API key needed.
# Set to "false" to connect to a live Vinly API instead.
#
NEXT_PUBLIC_DEMO_MODE=true

# ─── Live API (only used when DEMO_MODE is false) ──────────────────────────
#
# Your Vinly API base URL and key.
# Get these from your Vinly dashboard at https://vinly.co/settings/developer
#
# NEXT_PUBLIC_API_URL=https://api.vinly.co/v1
# VINLY_API_KEY=your_api_key_here
# NEXT_PUBLIC_ORG_ID=your_organization_id
